{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "rewrites": [
    { "source": "/(query|health|molecules|agents/status|experiments/.*)", "destination": "api/index.py" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
